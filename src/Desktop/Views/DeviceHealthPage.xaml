<Page
    x:Class="ITSupportNative.Desktop.Views.DeviceHealthPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:ITSupportNative.Desktop.Models">
    <ScrollViewer>
        <StackPanel
            MaxWidth="1120"
            Padding="32,28,32,48"
            HorizontalAlignment="Stretch"
            Spacing="20">
            <StackPanel Spacing="6">
                <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Salud del equipo" />
                <TextBlock
                    Style="{StaticResource SecondaryTextStyle}"
                    Text="Señales fijas para validar el diseño. No se recopila inventario real." />
            </StackPanel>
            <Border
                Padding="24"
                Background="{StaticResource AppBrandBrush}"
                CornerRadius="16">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon FontSize="36" Foreground="White" Glyph="&#xE73E;" />
                    <StackPanel Grid.Column="1">
                        <TextBlock
                            Foreground="White"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="El equipo está en buen estado" />
                        <TextBlock Foreground="#E8F3FC" Text="Resumen generado con datos sintéticos." />
                    </StackPanel>
                    <Border
                        Grid.Column="2"
                        Padding="12,7"
                        Background="#28FFFFFF"
                        CornerRadius="14">
                        <TextBlock Foreground="White" Text="Sin alertas críticas" />
                    </Border>
                </Grid>
            </Border>
            <GridView
                AutomationProperties.Name="Métricas de salud"
                IsItemClickEnabled="False"
                IsTabStop="False"
                ItemsSource="{x:Bind ViewModel.Metrics}">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid
                            ItemHeight="158"
                            ItemWidth="330"
                            Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="models:StatusMetric">
                        <Border
                            Width="316"
                            Height="144"
                            Margin="0,0,14,14"
                            AutomationProperties.Name="{x:Bind Label}"
                            Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <FontIcon
                                    HorizontalAlignment="Left"
                                    FontSize="23"
                                    Foreground="{StaticResource AppBrandBrush}"
                                    Glyph="{x:Bind Glyph}" />
                                <TextBlock
                                    Grid.Row="1"
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind Value}" />
                                <StackPanel Grid.Row="2">
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind Label}" />
                                    <TextBlock
                                        FontSize="12"
                                        Style="{StaticResource SecondaryTextStyle}"
                                        Text="{x:Bind Detail}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
            <InfoBar
                IsClosable="False"
                IsOpen="True"
                Message="El DeviceAgent ya implementa diagnósticos de solo lectura, pero esta vista continúa usando datos sintéticos y todavía no se conecta al agente."
                Severity="Informational"
                Title="Estado de integración" />
        </StackPanel>
    </ScrollViewer>
</Page>
