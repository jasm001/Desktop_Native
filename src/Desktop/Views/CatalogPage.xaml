<Page
    x:Class="ITSupportNative.Desktop.Views.CatalogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:ITSupportNative.Desktop.Models">
    <ScrollViewer>
        <StackPanel
            MaxWidth="1320"
            Padding="32,28,32,48"
            HorizontalAlignment="Stretch"
            Spacing="20">
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Catálogo de software" />
                    <TextBlock
                        Style="{StaticResource SecondaryTextStyle}"
                        Text="Contenido sintético para validar la experiencia. No instala software." />
                </StackPanel>
                <Border Grid.Column="1" Style="{StaticResource PillBorderStyle}">
                    <TextBlock VerticalAlignment="Center" Text="{x:Bind ViewModel.ProductCountLabel}" />
                </Border>
            </Grid>
            <AutoSuggestBox
                AutomationProperties.Name="Buscar software en el catálogo"
                PlaceholderText="Buscar por nombre o categoría" />
            <GridView
                AutomationProperties.Name="Productos del catálogo"
                IsItemClickEnabled="False"
                IsTabStop="False"
                ItemsSource="{x:Bind ViewModel.Software}">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid
                            ItemHeight="184"
                            ItemWidth="310"
                            Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="models:SoftwarePreview">
                        <Border
                            Width="296"
                            Height="170"
                            Margin="0,0,14,14"
                            AutomationProperties.Name="{x:Bind Name}"
                            Style="{StaticResource CardBorderStyle}">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Width="44"
                                        Height="44"
                                        Background="{ThemeResource AppSubtleBackgroundBrush}"
                                        CornerRadius="10">
                                        <FontIcon
                                            FontSize="21"
                                            Foreground="{StaticResource AppBrandBrush}"
                                            Glyph="{x:Bind Glyph}" />
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind Name}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            FontSize="12"
                                            Style="{StaticResource SecondaryTextStyle}"
                                            Text="{x:Bind Category}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock
                                    Grid.Row="1"
                                    Style="{StaticResource SecondaryTextStyle}"
                                    Text="Información local de disponibilidad y compatibilidad." />
                                <Grid Grid.Row="2">
                                    <TextBlock FontSize="12" Text="{x:Bind Version}" />
                                    <Border
                                        HorizontalAlignment="Right"
                                        Style="{StaticResource PillBorderStyle}">
                                        <TextBlock FontSize="12" Text="{x:Bind Status}" />
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </StackPanel>
    </ScrollViewer>
</Page>
