<Page
    x:Class="ITSupportNative.Desktop.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:ITSupportNative.Desktop.Models">
    <ScrollViewer>
        <StackPanel
            MaxWidth="1320"
            Padding="32,28,32,48"
            HorizontalAlignment="Stretch"
            Spacing="20">
            <StackPanel Spacing="6">
                <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Hola, Alex" />
                <TextBlock
                    Style="{StaticResource SecondaryTextStyle}"
                    Text="¿En qué podemos ayudarte hoy?" />
            </StackPanel>
            <Border
                Padding="28"
                Background="{StaticResource AppBrandBrush}"
                CornerRadius="16">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel MaxWidth="720" Spacing="10">
                        <TextBlock
                            Foreground="White"
                            FontSize="26"
                            FontWeight="SemiBold"
                            Text="Soporte claro, seguro y a tu alcance"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Foreground="#E8F3FC"
                            FontSize="15"
                            Text="Consulta el catálogo, revisa tu equipo o recibe orientación. Esta versión usa datos locales y no ejecuta acciones."
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <FontIcon
                        Grid.Column="1"
                        AutomationProperties.Name="Icono de soporte"
                        FontSize="58"
                        Foreground="#BFDDF4"
                        Glyph="&#xE8BD;" />
                </Grid>
            </Border>
            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Acciones rápidas" />
            <GridView
                AutomationProperties.Name="Acciones rápidas"
                IsItemClickEnabled="False"
                IsTabStop="False"
                ItemsSource="{x:Bind ViewModel.QuickActions}">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid
                            ItemHeight="142"
                            ItemWidth="258"
                            Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="models:QuickAction">
                        <Border
                            Width="246"
                            Height="130"
                            Margin="0,0,12,12"
                            AutomationProperties.Name="{x:Bind Title}"
                            Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <FontIcon
                                    HorizontalAlignment="Left"
                                    FontSize="24"
                                    Foreground="{StaticResource AppBrandBrush}"
                                    Glyph="{x:Bind Glyph}" />
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" />
                                <TextBlock
                                    FontSize="12"
                                    Style="{StaticResource SecondaryTextStyle}"
                                    Text="{x:Bind Description}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
            <Grid x:Name="DashboardGrid" ColumnSpacing="18" RowSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.95*" />
                    <ColumnDefinition Width="1.05*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border x:Name="HealthCard" Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="16">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Salud del equipo" />
                            <TextBlock
                                FontSize="12"
                                Style="{StaticResource SecondaryTextStyle}"
                                Text="Resumen local con valores sintéticos" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.HealthMetrics}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:StatusMetric">
                                    <Grid Padding="0,8" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon
                                            FontSize="18"
                                            Foreground="{StaticResource AppBrandBrush}"
                                            Glyph="{x:Bind Glyph}" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind Label}" />
                                            <TextBlock
                                                FontSize="12"
                                                Style="{StaticResource SecondaryTextStyle}"
                                                Text="{x:Bind Detail}" />
                                        </StackPanel>
                                        <TextBlock
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind Value}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border
                    x:Name="SoftwareCard"
                    Grid.Column="1"
                    Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="16">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Software destacado" />
                            <TextBlock
                                FontSize="12"
                                Style="{StaticResource SecondaryTextStyle}"
                                Text="Vista previa del catálogo local" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.FeaturedSoftware}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SoftwarePreview">
                                    <Grid Padding="0,9" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Width="38"
                                            Height="38"
                                            Background="{ThemeResource AppSubtleBackgroundBrush}"
                                            CornerRadius="8">
                                            <FontIcon
                                                FontSize="18"
                                                Foreground="{StaticResource AppBrandBrush}"
                                                Glyph="{x:Bind Glyph}" />
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                                            <TextBlock
                                                FontSize="12"
                                                Style="{StaticResource SecondaryTextStyle}"
                                                Text="{x:Bind Category}" />
                                        </StackPanel>
                                        <TextBlock
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Text="{x:Bind Status}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border
                    x:Name="ActivityCard"
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Actividad reciente" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.RecentActivity}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:ActivityPreview">
                                    <Grid Padding="0,8" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon
                                            FontSize="18"
                                            Foreground="{StaticResource AppBrandBrush}"
                                            Glyph="{x:Bind Glyph}" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" />
                                            <TextBlock
                                                FontSize="12"
                                                Style="{StaticResource SecondaryTextStyle}"
                                                Text="{x:Bind Detail}" />
                                        </StackPanel>
                                        <TextBlock
                                            Grid.Column="2"
                                            FontSize="12"
                                            Style="{StaticResource SecondaryTextStyle}"
                                            Text="{x:Bind Timestamp}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup>
                        <VisualState x:Name="NarrowDashboard">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="0" />
                            </VisualState.StateTriggers>
                            <VisualState.Setters>
                                <Setter Target="HealthCard.(Grid.ColumnSpan)" Value="2" />
                                <Setter Target="SoftwareCard.(Grid.Row)" Value="1" />
                                <Setter Target="SoftwareCard.(Grid.Column)" Value="0" />
                                <Setter Target="SoftwareCard.(Grid.ColumnSpan)" Value="2" />
                                <Setter Target="ActivityCard.(Grid.Row)" Value="2" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="WideDashboard">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="920" />
                            </VisualState.StateTriggers>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
