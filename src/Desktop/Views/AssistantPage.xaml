<Page
    x:Class="ITSupportNative.Desktop.Views.AssistantPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:ITSupportNative.Desktop.Models">
    <Grid MaxWidth="1120" Padding="32,28,32,48" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Spacing="6">
            <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Asistente" />
            <TextBlock
                Style="{StaticResource SecondaryTextStyle}"
                Text="Orientación determinista de demostración. Una consulta nunca crea una solicitud." />
        </StackPanel>
        <ScrollViewer
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto">
            <Border
                Margin="0,24"
                Style="{StaticResource CardBorderStyle}">
                <StackPanel
                    MaxWidth="680"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="18">
                    <Border
                        Width="64"
                        Height="64"
                        Background="{ThemeResource AppSubtleBackgroundBrush}"
                        CornerRadius="32">
                        <FontIcon
                            FontSize="30"
                            Foreground="{StaticResource AppBrandBrush}"
                            Glyph="&#xE8BD;" />
                    </Border>
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="¿Cómo puedo orientarte?"
                        TextAlignment="Center" />
                    <TextBlock
                        Style="{StaticResource SecondaryTextStyle}"
                        Text="Elige una intención fija. No hay IA, tickets reales ni acciones sobre el equipo."
                        TextAlignment="Center" />
                <Border
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="Estado de la conversación"
                    Style="{StaticResource PillBorderStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.StateLabel, Mode=OneWay}" />
                        <TextBlock
                            Style="{StaticResource SecondaryTextStyle}"
                            Text="{x:Bind ViewModel.Response, Mode=OneWay}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            FontSize="12"
                            Text="{x:Bind ViewModel.RequestReference, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <ItemsControl ItemsSource="{x:Bind ViewModel.Suggestions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:AssistantSuggestion">
                            <Button
                                Margin="0,5"
                                HorizontalAlignment="Stretch"
                                AutomationProperties.Name="{x:Bind Title}"
                                Command="{x:Bind Command}">
                                <Grid MinWidth="420" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        Foreground="{StaticResource AppBrandBrush}"
                                        Glyph="{x:Bind Glyph}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" />
                                        <TextBlock
                                            FontSize="12"
                                            Style="{StaticResource SecondaryTextStyle}"
                                            Text="{x:Bind Prompt}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <StackPanel
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        AutomationProperties.Name="Continuar propuesta"
                        Command="{x:Bind ViewModel.ContinueCommand}"
                        Content="Continuar" />
                    <Button
                        AutomationProperties.Name="Confirmar solicitud sintética"
                        Command="{x:Bind ViewModel.ConfirmCommand}"
                        Content="Confirmar" />
                    <Button
                        AutomationProperties.Name="Cancelar propuesta"
                        Command="{x:Bind ViewModel.CancelCommand}"
                        Content="Cancelar" />
                </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
        <Grid Grid.Row="2" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox
                AutomationProperties.Name="Escribir una consulta"
                IsEnabled="{x:Bind ViewModel.IsFreeTextEnabled, Mode=OneWay}"
                PlaceholderText="{x:Bind ViewModel.FreeTextPlaceholder, Mode=OneWay}"
                Text="{x:Bind ViewModel.DraftMessage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button
                Grid.Column="1"
                AutomationProperties.Name="Enviar consulta"
                Command="{x:Bind ViewModel.SendMessageCommand}">
                <FontIcon Glyph="&#xE724;" />
            </Button>
        </Grid>
    </Grid>
</Page>
