<Page
    x:Class="ITSupportNative.Desktop.Views.AssistantPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:ITSupportNative.Desktop.Models">
    <Grid MaxWidth="1120" Padding="32,28,32,48" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Asistente" />
            <TextBlock
                Style="{StaticResource SecondaryTextStyle}"
                Text="Orientacion informativa de demostracion. Una consulta nunca crea una solicitud." />
        </StackPanel>

        <ScrollViewer
            x:Name="ChatScrollViewer"
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto">
            <Border
                Margin="0,24"
                Style="{StaticResource CardBorderStyle}">
                <StackPanel
                    MaxWidth="720"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="18">
                    <Border
                        Width="64"
                        Height="64"
                        Background="{ThemeResource AppSubtleBackgroundBrush}"
                        CornerRadius="32">
                        <FontIcon
                            FontSize="30"
                            Foreground="{StaticResource AppBrandBrush}"
                            Glyph="&#xE8BD;" />
                    </Border>
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="Como puedo orientarte?"
                        TextAlignment="Center" />
                    <TextBlock
                        Style="{StaticResource SecondaryTextStyle}"
                        Text="Elige una intencion fija o consulta Hermes local. La IA no crea acciones, tickets ni solicitudes."
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />

                    <ItemsControl
                        HorizontalAlignment="Stretch"
                        AutomationProperties.Name="Historial del asistente"
                        ItemsSource="{x:Bind ViewModel.ChatMessages, Mode=OneWay}">
                        <ItemsControl.ItemContainerTransitions>
                            <TransitionCollection>
                                <EntranceThemeTransition FromVerticalOffset="14" />
                            </TransitionCollection>
                        </ItemsControl.ItemContainerTransitions>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:AssistantChatMessage">
                                <Grid
                                    Margin="0,0,0,10"
                                    HorizontalAlignment="{x:Bind Alignment}">
                                    <Border
                                        MaxWidth="600"
                                        MinWidth="240"
                                        Padding="14,12"
                                        AutomationProperties.Name="{x:Bind Author}"
                                        Style="{StaticResource PillBorderStyle}">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon
                                                FontSize="18"
                                                Foreground="{StaticResource AppBrandBrush}"
                                                Glyph="{x:Bind Glyph}" />
                                            <StackPanel Grid.Column="1" Spacing="5">
                                                <TextBlock
                                                    FontWeight="SemiBold"
                                                    Text="{x:Bind Author}" />
                                                <TextBlock
                                                    Style="{StaticResource SecondaryTextStyle}"
                                                    Text="{x:Bind Body}"
                                                    TextWrapping="WrapWholeWords" />
                                                <TextBlock
                                                    FontSize="12"
                                                    Text="{x:Bind Detail}"
                                                    TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border
                        HorizontalAlignment="Left"
                        AutomationProperties.Name="Hermes local esta consultando"
                        Style="{StaticResource PillBorderStyle}"
                        Visibility="{x:Bind ToVisibility(ViewModel.IsWaitingForAssistant), Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <ProgressRing
                                Width="20"
                                Height="20"
                                IsActive="{x:Bind ViewModel.IsWaitingForAssistant, Mode=OneWay}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Style="{StaticResource SecondaryTextStyle}"
                                Text="Hermes local esta escribiendo..." />
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{x:Bind ViewModel.Suggestions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:AssistantSuggestion">
                                <Button
                                    Margin="0,5"
                                    HorizontalAlignment="Stretch"
                                    AutomationProperties.Name="{x:Bind Title}"
                                    Command="{x:Bind Command}">
                                    <Grid MinWidth="420" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon
                                            Foreground="{StaticResource AppBrandBrush}"
                                            Glyph="{x:Bind Glyph}" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" />
                                            <TextBlock
                                                FontSize="12"
                                                Style="{StaticResource SecondaryTextStyle}"
                                                Text="{x:Bind Prompt}"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            AutomationProperties.Name="Continuar propuesta"
                            Command="{x:Bind ViewModel.ContinueCommand}"
                            Content="Continuar" />
                        <Button
                            AutomationProperties.Name="Confirmar solicitud sintetica"
                            Command="{x:Bind ViewModel.ConfirmCommand}"
                            Content="Confirmar" />
                        <Button
                            AutomationProperties.Name="Cancelar propuesta"
                            Command="{x:Bind ViewModel.CancelCommand}"
                            Content="Cancelar" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <Grid Grid.Row="2" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox
                AutomationProperties.Name="Escribir una consulta"
                IsEnabled="{x:Bind ViewModel.IsFreeTextEnabled, Mode=OneWay}"
                KeyDown="MessageTextBox_KeyDown"
                PlaceholderText="{x:Bind ViewModel.FreeTextPlaceholder, Mode=OneWay}"
                Text="{x:Bind ViewModel.DraftMessage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button
                Grid.Column="1"
                AutomationProperties.Name="Enviar consulta"
                Command="{x:Bind ViewModel.SendMessageCommand}">
                <FontIcon Glyph="&#xE724;" />
            </Button>
        </Grid>
    </Grid>
</Page>
