<Page
    x:Class="ITSupportNative.Desktop.Views.RequestsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:ITSupportNative.Desktop.Models">
    <ScrollViewer>
        <StackPanel
            MaxWidth="1120"
            Padding="32,28,32,48"
            HorizontalAlignment="Stretch"
            Spacing="20">
            <StackPanel Spacing="6">
                <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Solicitudes" />
                <TextBlock
                    Style="{StaticResource SecondaryTextStyle}"
                    Text="Historial sintético para validar estados y navegación." />
            </StackPanel>
            <InfoBar
                IsClosable="False"
                IsOpen="True"
                Message="Estas solicitudes son ejemplos locales. No se enviaron a ningún sistema."
                Severity="Informational"
                Title="Modo de demostración" />
            <ItemsControl ItemsSource="{x:Bind ViewModel.Requests}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:RequestPreview">
                        <Border Margin="0,0,0,12" Style="{StaticResource CardBorderStyle}">
                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Width="44"
                                    Height="44"
                                    Background="{ThemeResource AppSubtleBackgroundBrush}"
                                    CornerRadius="10">
                                    <FontIcon
                                        Foreground="{StaticResource AppBrandBrush}"
                                        Glyph="&#xE8A5;" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" />
                                    <TextBlock
                                        FontSize="12"
                                        Style="{StaticResource SecondaryTextStyle}"
                                        Text="{x:Bind Detail}" />
                                    <TextBlock
                                        FontFamily="Consolas"
                                        FontSize="12"
                                        Text="{x:Bind Reference}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Right" Spacing="6">
                                    <Border Style="{StaticResource PillBorderStyle}">
                                        <TextBlock FontSize="12" Text="{x:Bind State}" />
                                    </Border>
                                    <TextBlock
                                        FontSize="12"
                                        Style="{StaticResource SecondaryTextStyle}"
                                        Text="{x:Bind UpdatedAt}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
